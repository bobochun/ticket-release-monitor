# Copy this file to .env and fill in your values.

# Telegram bot token from BotFather.
TELEGRAM_BOT_TOKEN=

# Telegram chat ID. You can get it from your bot updates.
TELEGRAM_CHAT_ID=

# Optional: set to 1 to disable browser screenshots in notifications.
DISABLE_SCREENSHOTS=1

# Optional: set to chromium, firefox, or webkit.
BROWSER_NAME=chromium

# Optional: global navigation timeout in milliseconds.
NAVIGATION_TIMEOUT_MS=30000
