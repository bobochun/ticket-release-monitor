{
  "name": "ticket-radar",
  "version": "0.2.0",
  "description": "Ticket Radar: safe 24/7 ticket availability monitoring with web/mobile dashboard and notifications.",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "worker": "tsx scripts/worker.ts",
    "check": "tsx scripts/check.ts",
    "discover": "tsx scripts/discover.ts",
    "db:init": "tsx scripts/db-init.ts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "next lint || eslint .",
    "format": "prettier --write ."
