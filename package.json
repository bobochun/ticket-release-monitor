  "version": "0.1.0",
  "description": "A conservative ticket release monitoring notifier with manual purchase only.",
  "type": "module",
  "private": true,
  "scripts": {
    "check": "tsx src/index.ts check",
    "watch": "tsx src/index.ts watch",
    "discover": "tsx src/index.ts discover",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write ."
